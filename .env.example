# Supabase (required for auth + database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL (leave empty for local dev — Vite proxy handles it)
# Set to your deployed backend URL for production (e.g. https://your-backend.railway.app)
VITE_API_BASE_URL=

# Quarkus backend needs this as a system env var (NOT in this file):
# export ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
